# =============================================================================
# Lexy AI Assistant — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
#
# REQUIRED: At least one AI provider API key.
# RECOMMENDED: Groq (free) for best performance.
# =============================================================================

# --- AI Provider: Groq (recommended, free tier available) ---
# Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- AI Provider: Google Gemini (fallback) ---
# Sign up: https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# --- Telegram Bot (optional) ---
# Create a bot: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Admin Password (optional, default: admin123) ---
# Used for admin/owner mode in chat
ADMIN_PASSWORD=admin123

# --- Brain Secret (optional) ---
# Shared secret between WhatsApp bridge and brain server
BRAIN_SECRET=
